{
  "name": "nasa-picture-proxy",
  "private": true,
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:api": "wrangler dev",
    "dev:landing": "npm run dev --prefix landing",
    "log": "./scripts/log.sh watch all",
    "log:tail": "./scripts/log.sh tail all",
    "log:api": "./scripts/log.sh watch api",
    "log:api:tail": "./scripts/log.sh tail api",
    "log:landing": "./scripts/log.sh watch landing",
    "log:landing:tail": "./scripts/log.sh tail landing",
    "log:prod": "./scripts/log-prod.sh start",
    "log:prod:tail": "./scripts/log.sh tail prod",
    "log:prod:watch": "./scripts/log.sh watch prod",
    "log:prod:stop": "./scripts/log-prod.sh stop",  
    "status": "./scripts/status.sh",
    "stop": "./scripts/stop.sh",
    "build:landing": "npm run build --prefix landing",
    "deploy": "npm run deploy:api && npm run deploy:landing",
    "deploy:api": "wrangler deploy",
    "deploy:landing": "npm run build:landing && wrangler pages deploy landing/dist/ --project-name nasapicture-landing"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241004.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.77.0"
  }
}
